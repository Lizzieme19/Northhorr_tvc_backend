# Production Environment Variables Template for Self-Hosted Setup
# Copy this file to .env on your droplet and fill in the actual values

# Database Configuration (Self-hosted PostgreSQL)
DB_PASSWORD=your_strong_database_password_here

# JWT Configuration (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=northhorr

# Backblaze B2 (S3-compatible)
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_app_key
B2_BUCKET_NAME=northhorr
B2_BUCKET_ID=your_b2_bucket_id

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=northhorrtvc@gmail.com

# Frontend URL (Vercel deployment)
FRONTEND_URL=https://your-vercel-app.vercel.app
