// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
  DEPT_HEAD
  FINANCE
}

enum ApplicationType {
  DIRECT
  KUCCPS
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum StudentStatus {
  ACTIVE
  DEFERRED
  GRADUATED
  WITHDRAWN
}

enum Intake {
  JANUARY
  MAY
  SEPTEMBER
}

enum FeeType {
  ADMISSION
  KUCCPS
  STUDENT_ID
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       Role     @default(STUDENT)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student           Student?
  dept_head_of      Department?       @relation("DeptHead")
  reviewed_apps     Application[]     @relation("ReviewedBy")
  generated_letters AdmissionLetter[] @relation("GeneratedBy")
  fee_records       FeeRecord[]       @relation("ReceivedBy")
  refresh_tokens    RefreshToken[]
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())
}

model Department {
  id           String  @id @default(uuid())
  name         String  @unique
  slug         String  @unique
  tagline      String?
  description  String?
  icon         String?
  image_url    String?
  head_user_id String? @unique

  head         User?         @relation("DeptHead", fields: [head_user_id], references: [id])
  courses      Course[]
  applications Application[]
  students     Student[]
}

model Course {
  id            String @id @default(uuid())
  name          String
  levels        String // e.g. "Level 3, 4, 5"
  shortcode     String @unique
  department_id String

  department   Department    @relation(fields: [department_id], references: [id])
  applications Application[]
  students     Student[]
}

model Application {
  id             String          @id @default(uuid())
  application_no String          @unique
  type           ApplicationType @default(DIRECT)

  // Personal
  surname       String
  other_names   String
  gender        String
  date_of_birth DateTime
  nationality   String   @default("Kenyan")
  religion      String?
  id_number     String?
  birth_cert_no String?

  // Contact
  email   String
  phone   String
  address String?

  // Academic
  kcpe_index      String?
  kcpe_marks      Int?
  kcse_index      String?
  kcse_grade      String?
  previous_school String?

  // Parent/Guardian
  parent_names        String?
  parent_relationship String?
  parent_phone        String?
  parent_email        String?

  // Medical
  medical_conditions String?
  allergies          String?
  disability         String?
  emergency_person   String?
  emergency_phone    String?

  // Course selection
  course_id     String?
  department_id String?
  level_applied String?

  // Status
  status       ApplicationStatus @default(PENDING)
  reviewed_by  String?
  reviewed_at  DateTime?
  review_notes String?

  // Documents (B2 keys)
  doc_kcpe       String?
  doc_kcse       String?
  doc_id_copy    String?
  doc_birth_cert String?
  doc_medical    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  reviewer   User?       @relation("ReviewedBy", fields: [reviewed_by], references: [id])
  course     Course?     @relation(fields: [course_id], references: [id])
  department Department? @relation(fields: [department_id], references: [id])
  student    Student?
}

model Student {
  id             String @id @default(uuid())
  admission_no   String @unique
  user_id        String @unique
  application_id String @unique

  course_id     String
  department_id String
  level         String
  intake        Intake
  year          Int

  photo_url String?

  // Fee flags
  helb_applied        Boolean @default(false)
  admission_fee_paid  Boolean @default(false)
  kuccps_fee_paid     Boolean @default(false)
  student_id_fee_paid Boolean @default(false)

  status     StudentStatus @default(ACTIVE)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  user             User             @relation(fields: [user_id], references: [id])
  application      Application      @relation(fields: [application_id], references: [id])
  course           Course           @relation(fields: [course_id], references: [id])
  department       Department       @relation(fields: [department_id], references: [id])
  admission_letter AdmissionLetter?
  fee_records      FeeRecord[]
}

model AdmissionLetter {
  id            String   @id @default(uuid())
  student_id    String   @unique
  generated_by  String
  generated_at  DateTime @default(now())
  letter_url    String // B2 key / URL
  sent_by_email Boolean  @default(false)

  student   Student @relation(fields: [student_id], references: [id])
  generator User    @relation("GeneratedBy", fields: [generated_by], references: [id])
}

model FeeRecord {
  id          String   @id @default(uuid())
  student_id  String
  fee_type    FeeType
  amount      Float
  paid_at     DateTime @default(now())
  received_by String
  notes       String?

  student  Student @relation(fields: [student_id], references: [id])
  receiver User    @relation("ReceivedBy", fields: [received_by], references: [id])
}
