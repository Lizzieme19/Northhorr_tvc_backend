// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
  DEPT_HEAD
  FINANCE
  STAFF
  PROCUREMENT
  HR
}

enum ApplicationType {
  DIRECT
  KUCCPS
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum StudentStatus {
  ACTIVE
  DEFERRED
  GRADUATED
  WITHDRAWN
}

enum Intake {
  JANUARY
  MAY
  SEPTEMBER
}

enum FeeTypeEnum {
  ADMISSION
  KUCCPS
  STUDENT_ID
}

// Staff Management Enums
enum EmploymentStatus {
  ACTIVE
  PROBATION
  TERMINATED
  RESIGNED
  RETIRED
  ON_LEAVE
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  COMPASSIONATE
  STUDY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Procurement Enums
enum RequisitionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ORDERED
  COMPLETED
  CANCELLED
}

enum LPOStatus {
  DRAFT
  APPROVED
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  password             String
  role                 Role     @default(STUDENT)
  is_active            Boolean  @default(true)
  must_change_password Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  student           Student?
  dept_head_of      Department? @relation("DeptHead")
  reviewed_apps     Application[] @relation("ReviewedBy")
  generated_letters AdmissionLetter[] @relation("GeneratedBy")
  fee_records       FeeRecord[] @relation("ReceivedBy")
  refresh_tokens    RefreshToken[]
  staff             Staff?
  approved_leaves   LeaveRequest[] @relation("ApprovedBy")
  created_requisitions PurchaseRequisition[] @relation("CreatedBy")
  approved_requisitions PurchaseRequisition[] @relation("ApprovedBy")
  uploaded_resources Resource[]
  uploaded_news     News[]
  approved_lpos      LPO[] @relation("ApprovedBy")
  promoted_progressions StudentProgression[] @relation("ProgressionPromoter")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())
}

model Department {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  tagline     String?
  description String?
  icon        String?
  image_url   String?
  head_user_id String? @unique
  shortcode   String  @unique // e.g. "ECS", "CEE", "DSW"
  intake_months String  @default("J,M,S") // Comma-separated month shortcodes e.g. "J,M,S"

  head        User?         @relation("DeptHead", fields: [head_user_id], references: [id])
  courses     Course[]
  applications Application[]
  students    Student[]
  staff       Staff[]
  budgets     Budget[]
  purchase_requisitions PurchaseRequisition[]
  lpos        LPO[]
  assets      Asset[]
}

model Course {
  id            String  @id @default(uuid())
  name          String
  levels        String  // e.g. "Level 3, 4, 5"
  shortcode     String  @unique
  department_id String

  department    Department    @relation(fields: [department_id], references: [id])
  applications  Application[]
  students      Student[]
  feeTypes      FeeType[]
}

model Application {
  id              String            @id @default(uuid())
  application_no  String            @unique
  type            ApplicationType   @default(DIRECT)

  // Personal
  surname         String
  other_names     String
  gender          String
  date_of_birth   DateTime
  nationality     String            @default("Kenyan")
  religion        String?
  id_number       String?
  birth_cert_no   String?

  // Contact
  email           String
  phone           String
  address         String?

  // Academic
  kcpe_index      String?
  kcpe_marks      Int?
  kcse_index      String?
  kcse_grade      String?
  previous_school String?

  // Parent/Guardian
  parent_names          String?
  parent_relationship   String?
  parent_phone          String?
  parent_email          String?

  // Father Information
  father_present        Boolean  @default(true)
  father_name           String?
  father_phone          String?
  father_email          String?
  father_occupation     String?

  // Mother Information
  mother_present        Boolean  @default(true)
  mother_name           String?
  mother_phone          String?
  mother_email          String?
  mother_occupation     String?

  // Medical
  medical_conditions    String?
  allergies             String?
  disability            String?
  emergency_person      String?
  emergency_phone       String?

  // Course selection
  course_id       String?
  department_id   String?
  level_applied   String?

  // Status
  status          ApplicationStatus @default(PENDING)
  reviewed_by     String?
  reviewed_at     DateTime?
  review_notes    String?

  // Documents (B2 keys)
  doc_kcpe        String?
  doc_kcse        String?
  doc_id_copy     String?
  doc_birth_cert  String?
  doc_medical     String?
  // ID copies (front and back)
  id_copy_front_url   String?
  id_copy_back_url    String?
  parent_id_copy_front_url String?
  parent_id_copy_back_url  String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  reviewer        User?       @relation("ReviewedBy", fields: [reviewed_by], references: [id])
  course          Course?     @relation(fields: [course_id], references: [id])
  department      Department? @relation(fields: [department_id], references: [id])
  student         Student?
}

model Student {
  id              String        @id @default(uuid())
  admission_no    String        @unique
  user_id         String        @unique
  application_id  String        @unique

  course_id       String
  department_id   String
  level           String
  intake          Intake
  year            Int

  photo_url       String?
  profile_picture_url String? // Student profile picture for ID card

  // ID copies
  id_copy_front_url   String?
  id_copy_back_url    String?
  parent_id_copy_front_url String?
  parent_id_copy_back_url  String?

  // Additional documents
  medical_report_url      String?
  kcse_certificate_url    String?
  birth_certificate_url   String?
  other_documents_url     String? // For any other miscellaneous documents

  // Admission month shortcode (e.g., 'J', 'M', 'S')
  admission_month_shortcode String?

  // Fee flags
  helb_applied        Boolean @default(false)
  admission_fee_paid  Boolean @default(false)
  kuccps_fee_paid     Boolean @default(false)
  student_id_fee_paid Boolean @default(false)
  tuition_fee_paid    Boolean @default(false) // Manual tuition fee payment indication
  full_year_paid      Boolean @default(false) // Full-year tuition payment
  fee_adjustment      Float    @default(0) // Fee adjustment (discount/waiver amount)

  // Current term enrollment
  current_term_id String? // Active term for the student

  status          StudentStatus @default(ACTIVE)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  user            User          @relation(fields: [user_id], references: [id])
  application     Application   @relation(fields: [application_id], references: [id])
  course          Course        @relation(fields: [course_id], references: [id])
  department      Department    @relation(fields: [department_id], references: [id])
  admission_letter AdmissionLetter?
  fee_records     FeeRecord[]
  student_balances StudentBalance[]
  current_term    Term?         @relation("StudentCurrentTerm", fields: [current_term_id], references: [id])
  progressions    StudentProgression[]
}

model AdmissionLetter {
  id              String   @id @default(uuid())
  student_id      String   @unique
  generated_by    String
  generated_at    DateTime @default(now())
  letter_url      String   // B2 key / URL
  sent_by_email   Boolean  @default(false)

  student         Student  @relation(fields: [student_id], references: [id])
  generator       User     @relation("GeneratedBy", fields: [generated_by], references: [id])
}

model FeeRecord {
  id          String   @id @default(uuid())
  student_id  String
  fee_type_id String?  // Reference to FeeType (optional for backward compatibility)
  term_id     String?  // Link to term for balance calculation
  amount      Float
  reference_code String? @unique // Unique reference code for audit trail
  paid_at     DateTime @default(now())
  received_by String
  notes       String?

  student     Student  @relation(fields: [student_id], references: [id])
  receiver    User     @relation("ReceivedBy", fields: [received_by], references: [id])
  feeType     FeeType? @relation("FeeRecordFeeType", fields: [fee_type_id], references: [id])
  term        Term?    @relation("FeeRecordTerm", fields: [term_id], references: [id])
}

model IntakeMonth {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "JANUARY", "MAY", "SEPTEMBER"
  shortcode   String   @unique // e.g., "J", "M", "S"
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

// Staff Management Models
model Designation {
  id            String   @id @default(uuid())
  title         String   @unique
  grade_level   String?
  description   String?
  salary_min    Float?
  salary_max    Float?
  responsibilities String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  staff         Staff[]
}

model Staff {
  id                String   @id @default(uuid())
  user_id           String   @unique
  employee_number   String   @unique
  designation_id    String
  department_id     String
  reports_to_id     String?

  // Personal Details
  first_name        String
  last_name         String
  gender            String
  date_of_birth    DateTime
  phone             String
  address           String?
  emergency_contact String?
  emergency_phone   String?

  // Employment Details
  employment_status EmploymentStatus @default(ACTIVE)
  employment_type   String? // FULL_TIME, PART_TIME, CONTRACT
  date_hired        DateTime
  date_terminated   DateTime?
  termination_reason String?
  salary            Float
  bank_account      String?
  bank_name         String?
  kra_pin           String?
  nssf_number       String?
  nhif_number       String?

  // Profile
  profile_picture_url String?
  cv_url            String?
  certificates_url  String?

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id])
  designation       Designation @relation(fields: [designation_id], references: [id])
  department        Department @relation(fields: [department_id], references: [id])
  reports_to        Staff?   @relation("ReportsTo", fields: [reports_to_id], references: [id])
  subordinates      Staff[]  @relation("ReportsTo")
  leave_requests    LeaveRequest[]
  leave_balances    LeaveBalance[]
  employment_records EmploymentRecord[]
  custodied_assets  Asset[]
}

model LeaveRequest {
  id              String      @id @default(uuid())
  staff_id        String
  leave_type      LeaveType
  start_date      DateTime
  end_date        DateTime
  total_days      Int
  reason          String?
  status          LeaveStatus @default(PENDING)
  approved_by     String?
  approved_at     DateTime?
  rejection_reason String?
  attachments     String?

  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  staff           Staff       @relation(fields: [staff_id], references: [id])
  approver        User?       @relation("ApprovedBy", fields: [approved_by], references: [id])
}

model LeaveBalance {
  id              String   @id @default(uuid())
  staff_id        String
  leave_type      LeaveType
  year            Int
  total_days      Int
  used_days       Int      @default(0)
  carried_forward Int      @default(0)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  staff           Staff    @relation(fields: [staff_id], references: [id])

  @@unique([staff_id, leave_type, year])
}

model EmploymentRecord {
  id              String   @id @default(uuid())
  staff_id        String
  designation_id   String?
  department_id   String?
  title           String?
  salary          Float?
  start_date      DateTime
  end_date        DateTime?
  reason          String?

  created_at      DateTime @default(now())

  staff           Staff    @relation(fields: [staff_id], references: [id])
}

// Procurement Models
model Supplier {
  id              String   @id @default(uuid())
  name            String
  contact_person  String?
  email           String?
  phone           String
  address         String?
  city            String?
  country         String?
  tax_id          String?
  registration_number String?
  is_approved     Boolean  @default(false)
  rating          Float?   @default(0)
  notes           String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  rfqs            RFQ[]
  lpos            LPO[]
  invoices        SupplierInvoice[]
  quotations      Quotation[]
  inventory_items InventoryItem[]
}

model PurchaseRequisition {
  id              String            @id @default(uuid())
  requisition_no  String            @unique
  department_id   String
  requested_by    String
  approved_by     String?
  status          RequisitionStatus @default(DRAFT)
  priority        String?           // LOW, MEDIUM, HIGH, URGENT
  justification   String?
  total_amount    Float?
  approved_at     DateTime?
  rejection_reason String?

  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  department      Department        @relation(fields: [department_id], references: [id])
  requester       User              @relation("CreatedBy", fields: [requested_by], references: [id])
  approver        User?             @relation("ApprovedBy", fields: [approved_by], references: [id])
  items           RequisitionItem[]
  rfqs            RFQ[]
}

model RequisitionItem {
  id              String   @id @default(uuid())
  requisition_id  String
  item_name       String
  description     String?
  quantity        Int
  unit_price      Float?
  total_price     Float?
  specifications  String?

  created_at      DateTime @default(now())

  requisition     PurchaseRequisition @relation(fields: [requisition_id], references: [id], onDelete: Cascade)
}

model RFQ {
  id              String   @id @default(uuid())
  rfq_no          String   @unique
  requisition_id  String?
  title           String
  description     String?
  opening_date    DateTime
  closing_date    DateTime
  status          String   @default("OPEN") // OPEN, CLOSED, AWARDED, CANCELLED
  awarded_to      String?
  notes           String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  requisition     PurchaseRequisition? @relation(fields: [requisition_id], references: [id])
  supplier        Supplier? @relation(fields: [awarded_to], references: [id])
  quotations      Quotation[]
  lpos            LPO[]
}

model Quotation {
  id              String   @id @default(uuid())
  rfq_id          String
  supplier_id     String
  quotation_no    String
  amount          Float
  currency        String   @default("KES")
  validity_period Int?     // days
  notes           String?
  is_selected     Boolean  @default(false)

  submitted_at    DateTime @default(now())

  rfq             RFQ      @relation(fields: [rfq_id], references: [id])
  supplier        Supplier @relation(fields: [supplier_id], references: [id])
}

model LPO {
  id              String   @id @default(uuid())
  lpo_no          String   @unique
  rfq_id          String?
  supplier_id     String
  department_id   String
  approved_by     String?
  status          LPOStatus @default(DRAFT)
  issue_date      DateTime?
  delivery_date   DateTime?
  payment_terms   String?
  total_amount    Float
  currency        String   @default("KES")
  notes           String?
  pdf_url         String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  rfq             RFQ?      @relation(fields: [rfq_id], references: [id])
  supplier        Supplier  @relation(fields: [supplier_id], references: [id])
  department      Department @relation(fields: [department_id], references: [id])
  approver        User?     @relation("ApprovedBy", fields: [approved_by], references: [id])
  items           LPOItem[]
  grns            GRN[]
  invoices        SupplierInvoice[]
}

model LPOItem {
  id              String   @id @default(uuid())
  lpo_id          String
  item_name       String
  description     String?
  quantity        Int
  unit_price      Float
  total_price     Float
  specifications  String?

  created_at      DateTime @default(now())

  lpo             LPO      @relation(fields: [lpo_id], references: [id], onDelete: Cascade)
}

model GRN {
  id              String   @id @default(uuid())
  grn_no          String   @unique
  lpo_id          String
  received_by     String
  received_date   DateTime @default(now())
  status          String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  notes           String?
  discrepancies    String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  lpo             LPO      @relation(fields: [lpo_id], references: [id])
  items           GRNItem[]
}

model GRNItem {
  id              String   @id @default(uuid())
  grn_id          String
  item_name       String
  quantity_ordered Int
  quantity_received Int
  quantity_accepted Int
  batch_number    String?
  expiry_date     DateTime?
  condition       String? // GOOD, DAMAGED, DEFECTIVE
  notes           String?

  created_at      DateTime @default(now())

  grn             GRN      @relation(fields: [grn_id], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id              String   @id @default(uuid())
  item_code       String   @unique
  name            String
  description     String?
  category        String?
  unit_of_measure String?
  current_stock   Int      @default(0)
  minimum_stock   Int      @default(0)
  maximum_stock   Int?
  reorder_level   Int      @default(0)
  location        String?
  unit_cost       Float?
  supplier_id     String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  supplier        Supplier? @relation(fields: [supplier_id], references: [id])
  stock_movements StockMovement[]
}

model StockMovement {
  id              String   @id @default(uuid())
  inventory_item_id String
  movement_type   String   // IN, OUT, ADJUSTMENT
  quantity        Int
  reference       String?
  notes           String?
  performed_by    String?

  created_at      DateTime @default(now())

  inventory_item  InventoryItem @relation(fields: [inventory_item_id], references: [id])
}

model SupplierInvoice {
  id              String        @id @default(uuid())
  invoice_no      String        @unique
  lpo_id          String
  supplier_id     String
  amount          Float
  currency        String        @default("KES")
  invoice_date    DateTime
  due_date        DateTime?
  status          PaymentStatus @default(PENDING)
  paid_amount     Float         @default(0)
  payment_date    DateTime?
  notes           String?
  attachment_url  String?

  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  lpo             LPO           @relation(fields: [lpo_id], references: [id])
  supplier        Supplier      @relation(fields: [supplier_id], references: [id])
}

model Asset {
  id              String   @id @default(uuid())
  asset_code      String   @unique
  name            String
  description     String?
  category        String?
  serial_number   String?
  purchase_date   DateTime
  purchase_cost   Float
  current_value   Float?
  location        String?
  department_id   String?
  custodian_id    String?
  depreciation_rate Float?  // percentage
  accumulated_depreciation Float @default(0)
  useful_life     Int?     // years
  status          String   @default("ACTIVE") // ACTIVE, DISPOSED, WRITTEN_OFF
  disposal_date   DateTime?
  disposal_reason String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  department      Department? @relation(fields: [department_id], references: [id])
  custodian       Staff?   @relation(fields: [custodian_id], references: [id])
  maintenance_records MaintenanceRecord[]
}

model MaintenanceRecord {
  id              String   @id @default(uuid())
  asset_id        String
  maintenance_type String  // PREVENTIVE, CORRECTIVE
  description     String
  cost            Float?
  performed_by    String?
  performed_date  DateTime
  next_due_date   DateTime?

  created_at      DateTime @default(now())

  asset           Asset    @relation(fields: [asset_id], references: [id])
}

model Resource {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   // Prospectus, Forms, Timetables, Policies
  file_url    String   // S3 URL
  file_key    String   // S3 key for deletion
  file_type   String   // PDF, DOCX, ZIP, etc.
  file_size   String?  // Human readable size
  uploaded_by String   // Admin user ID

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  uploader    User     @relation(fields: [uploaded_by], references: [id])
}

model News {
  id          String   @id @default(uuid())
  title       String
  excerpt     String
  content     String?  // Full news content
  category    String   // News, Event, Announcement
  image_url   String?  // S3 URL for news image
  image_key   String?  // S3 key for deletion
  is_featured Boolean  @default(false)
  is_published Boolean @default(false)
  published_at DateTime?
  uploaded_by String   // Admin user ID

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  uploader    User     @relation(fields: [uploaded_by], references: [id])
}

model FeeType {
  id          String   @id @default(uuid())
  name        String   // e.g., "Admission Fee", "Tuition Fee", "Library Fee"
  code        String   @unique // e.g., "ADMISSION", "TUITION", "LIBRARY"
  description String?
  amount      Float    // Default amount
  is_active   Boolean  @default(true) // Enable/disable fee type
  is_required Boolean  @default(false) // Mandatory fee
  is_disabled Boolean  @default(false) // Additional flag for temporarily disabling fees
  applies_to  String   // ALL, SPECIFIC_COURSE, SPECIFIC_LEVEL
  course_id   String?  // If applies to specific course
  level       String?  // If applies to specific level (e.g., "Certificate", "Diploma")
  term_based  Boolean  @default(false) // Whether fee is per-term (like tuition)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  course      Course?  @relation(fields: [course_id], references: [id])
  fee_records FeeRecord[] @relation("FeeRecordFeeType")
}

model Term {
  id          String   @id @default(uuid())
  name        String   // e.g., "Term 1 2024", "Term 2 2024"
  start_date  DateTime
  end_date    DateTime
  academic_year String // e.g., "2024/2025"
  term_cost   Float    @default(0) // Configurable cost per term
  is_active   Boolean  @default(true)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  fee_records FeeRecord[] @relation("FeeRecordTerm")
  student_balances StudentBalance[]
  students Student[] @relation("StudentCurrentTerm")
  progressions StudentProgression[]
}

model StudentBalance {
  id          String   @id @default(uuid())
  student_id  String
  term_id     String
  level       String   // Level at time of enrollment
  total_fees  Float    @default(0)
  amount_paid Float    @default(0)
  balance     Float    @default(0)
  status      String   @default("PENDING") // PENDING, PARTIAL, PAID, OVERDUE

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  student     Student  @relation(fields: [student_id], references: [id])
  term        Term     @relation(fields: [term_id], references: [id])

  @@unique([student_id, term_id], name: "student_term")
}

model StudentProgression {
  id              String   @id @default(uuid())
  student_id      String
  from_level      String?  // Previous level (null for initial enrollment)
  to_level        String   // New level
  term_id         String   // Term when progression occurred
  academic_year   String   // Academic year
  promoted_by     String   // Admin who approved the progression
  notes           String?
  fee_clearance   Boolean  @default(false) // Whether fees were cleared before progression

  created_at      DateTime @default(now())

  student         Student  @relation(fields: [student_id], references: [id])
  term            Term     @relation(fields: [term_id], references: [id])
  promoter        User     @relation("ProgressionPromoter", fields: [promoted_by], references: [id])
}

model Budget {
  id              String   @id @default(uuid())
  department_id   String
  fiscal_year     Int
  category        String?
  allocated_amount Float
  spent_amount    Float    @default(0)
  remaining_amount Float
  status          String   @default("ACTIVE") // ACTIVE, CLOSED, FROZEN
  notes           String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  department      Department @relation(fields: [department_id], references: [id])

  @@unique([department_id, fiscal_year, category])
}

model AuditTrail {
  id              String   @id @default(uuid())
  user_id         String?
  action          String
  entity_type     String   // REQUISITION, LPO, GRN, INVOICE, etc.
  entity_id       String?
  old_values      String?  // JSON string
  new_values      String?  // JSON string
  ip_address      String?
  user_agent      String?

  created_at      DateTime @default(now())
}
